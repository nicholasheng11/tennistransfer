# Copy this file to ".env" (same folder) and fill in your token.
# The .env file is gitignored, so it will NOT be committed.
#
# HOW TO GET YOUR TOKEN:
#   1. Log in at https://app.utrsports.net (your premium account).
#   2. Open browser DevTools (F12) -> Application tab -> Cookies -> the utrsports/universaltennis domain.
#   3. Find the cookie named "jwt" and copy its (long) value.
#      (Alternatively: DevTools -> Network tab, click any api.utrsports.net request,
#       and copy the value after "Bearer " in the Authorization request header.)
#   4. Paste it below. Tokens expire after a while — just grab a fresh one when a run fails auth.

UTR_JWT=paste-your-jwt-token-here

# Base URL for the UTR API. Default is correct as of mid-2026; change only if a run shows it moved.
UTR_API_BASE=https://api.utrsports.net
